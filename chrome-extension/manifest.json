{
  "manifest_version": 3,
  "name": "Zim-Clipper (HunterOS)",
  "version": "1.0.0",
  "description": "Scrapes job descriptions directly into the RonnyZim OS Identity Matrix.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://shell.ronnyzim.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Abrir Zim-Clipper"
  },
  "background": {
    "service_worker": "background.js"
  }
}
